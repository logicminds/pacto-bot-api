{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacto-bot-api JSON-RPC catalog",
  "type": "object",
  "properties": {
    "openrpc": { "type": "string", "const": "1.3.1" },
    "info": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "params": { "type": "array" },
          "result": { "type": "object" }
        },
        "required": ["name"]
      }
    }
  }
}
