{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacto-bot-api.toml schema",
  "type": "object",
  "properties": {
    "daemon": {
      "type": "object",
      "properties": {
        "data_dir": { "type": "string" },
        "socket_path": { "type": "string" },
        "http_bind": { "type": "string" }
      }
    },
    "bots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "npub": { "type": "string" },
          "signing": { "type": "object" },
          "relays": { "type": "array", "items": { "type": "string" } },
          "capabilities": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["id", "npub", "signing"]
      }
    }
  }
}
