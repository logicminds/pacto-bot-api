{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pacto-bot-api.toml schema",
  "type": "object",
  "properties": {
    "daemon": {
      "type": "object",
      "properties": {
        "data_dir": { "type": "string" },
        "socket_path": { "type": "string" },
        "http_bind": { "type": "string" },
        "http_max_connections": { "type": "integer", "description": "Maximum concurrent HTTP connections" },
        "http_idle_timeout_secs": { "type": "integer", "description": "Idle timeout for HTTP keep-alive connections in seconds" }
      }
    },
    "bots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "npub": { "type": "string" },
          "signing": { "type": "object" },
          "relays": { "type": "array", "items": { "type": "string" } },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "display_name": { "type": "string", "description": "Human-readable display name for the bot profile" },
          "about": { "type": "string", "description": "Description text for the bot profile" },
          "picture": { "type": "string", "description": "URL to the bot's profile picture" }
        },
        "required": ["id", "npub", "signing"]
      }
    }
  }
}
